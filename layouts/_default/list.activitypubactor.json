{{- $ap := .Site.Params.activitypub -}}
{{- $domain := $ap.domain -}}
{{- $username := $ap.username -}}
{{- $pubkey := readFile "static/socialweb/publickey.pem" | strings.TrimSpace -}}
{
  "@context": ["https://www.w3.org/ns/activitystreams", "https://w3id.org/security/v1"],
  "id": "https://{{ $domain }}/@{{ $username }}",
  "type": "Person",
  "preferredUsername": {{ $ap.preferred_username | default $username | jsonify }},
  "name": {{ .Site.Title | jsonify }},
  "summary": {{ .Site.Params.description | jsonify }},
  "url": "https://{{ $domain }}",
  "inbox": "https://{{ $domain }}/activitypub/inbox",
  "outbox": "https://{{ $domain }}/socialweb/outbox.json",
  "followers": "https://{{ $domain }}/activitypub/followers",
  "following": "https://{{ $domain }}/activitypub/following.json",
  "icon": {"type": "Image", "mediaType": "image/png", "url": {{ $ap.avatar_url | jsonify }}},
  "publicKey": {
    "id": "https://{{ $domain }}/@{{ $username }}#main-key",
    "owner": "https://{{ $domain }}/@{{ $username }}",
    "publicKeyPem": {{ $pubkey | jsonify }}
  }
}
